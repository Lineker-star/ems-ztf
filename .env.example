# Web3Forms access key used by the contact form (src/components/ContactForm.tsx).
# Create a free key at https://web3forms.com/ using the contact form email
# (ems@ztfuniversity.com), then copy this file to .env.local and fill it in.
# This value is exposed to the browser (NEXT_PUBLIC_*) because the contact form
# submits directly from the static export with no backend of its own.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
